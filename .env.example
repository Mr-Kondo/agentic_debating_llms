OLLAMA_BASE_URL=http://localhost:11434
FACILITATOR_MODEL=llama3.1:latest
DEBATER_A_MODEL=gemma4:latest
DEBATER_B_MODEL=qwen3.5:latest
VALIDATOR_MODEL=rnj-1:latest
MODEL_KEEP_ALIVE=10m
MAX_TURNS=8
CONTINUATION_ROUNDS=0
SEARCH_COMMAND_TEMPLATE=ddgs text "{query}" --max-results 5
SEARCH_TIMEOUT_SECONDS=20
OLLAMA_TIMEOUT_SECONDS=60
MARKDOWN_LOG_DIR=./logs
INPUT_DIR=./in
OUTPUT_DIR=./out
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
